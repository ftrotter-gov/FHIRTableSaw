# Example environment variables for NDH slurp
#
# Copy to `.env` and adjust for your environment.
#
# Notes:
# - The slurper assumes the FHIR server is unauthenticated.
# - The DB URL is a standard SQLAlchemy URL.

# Basic Auth credentials for create_ndjson_from_api.py
# Preferred names:
FHIR_API_USERNAME=
FHIR_API_PASSWORD=

# Accepted aliases:
# FHIR_USERNAME=
# FHIR_PASSWORD=

# SQLAlchemy database URL for Postgres
# Format:
#   postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ndh

DB_SCHEMA=fhirtablesaw
