# Example environment variables for NDH slurp
#
# Copy to `.env` and adjust for your environment.
#
# Notes:
# - The slurper assumes the FHIR server is unauthenticated.
# - The DB URL is a standard SQLAlchemy URL.

# Basic Auth credentials for create_ndjson_from_api.py
# Preferred names:
FHIR_API_USERNAME=
FHIR_API_PASSWORD=

# FHIR base URL (used by go.py; if unset, defaults to the internal dev endpoint)
FHIR_SERVER_URL=https://dev.cnpd.internal.cms.gov/fhir/

# ============================================================================
# Data Directory Configuration (for three separate data sources)
# ============================================================================

# Test server FHIR data directory
TEST_FHIR_DIR=/path/to/test/fhir/data

# CMS FHIR data directory
CMS_FHIR_DIR=/path/to/cms/fhir/data

# Palantir FHIR data directory
PALANTIR_FHIR_DIR=/path/to/palantir/fhir/data

# Legacy variable (deprecated, but still supported for backward compatibility)
# FHIR_API_CACHE_FOLDER=

# Accepted aliases:
# FHIR_USERNAME=
# FHIR_PASSWORD=

# ============================================================================
# go_fast.py Configuration (FAST Pipeline: DuckDB → CSV → PostgreSQL)
# ============================================================================

# Number of resources to process per batch (default: 5000)
# Adjust this based on available memory and performance needs
BATCH_SIZE=5000

# Whether to upload CSV files to PostgreSQL automatically (default: false)
# Set to "true", "1", or "yes" to enable automatic uploads
UPLOAD_TO_POSTGRESQL=false

# PostgreSQL upload mode when UPLOAD_TO_POSTGRESQL is enabled (default: replace)
# Options: replace, append, fail
# - replace: Drop and recreate tables (use with caution!)
# - append: Add data to existing tables
# - fail: Fail if table already exists
UPLOAD_MODE=replace

# Directory for DuckDB temporary files (optional)
# If not set, falls back to FHIR_API_CACHE_FOLDER, then to NDJSON directory
TEMP_DIR=

# SQLAlchemy database URL for Postgres
# Format:
#   postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ndh

# ============================================================================
# Database Schema Configuration (for three separate data sources)
# ============================================================================

# Test server schema
TEST_FHIR_SCHEMA=fhirtablesaw_test

# CMS schema
CMS_FHIR_SCHEMA=fhirtablesaw_cms

# Palantir schema
PALANTIR_FHIR_SCHEMA=fhirtablesaw_palantir

# Legacy variable (deprecated, but still supported for backward compatibility)
# DB_SCHEMA=fhirtablesaw

