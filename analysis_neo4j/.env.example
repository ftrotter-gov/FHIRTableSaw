# Neo4j Configuration
# Copy this file to .env and set your actual password

# Neo4j authentication (format: username/password)
NEO4J_AUTH=neo4j/your_secure_password_here

# Neo4j password for scripts
NEO4J_PASSWORD=your_secure_password_here

# Neo4j connection details
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
