{
  "resourceType": "ViewDefinition",
  "url": "http://example.org/fhir/ViewDefinition/organization",
  "name": "organization",
  "title": "Organization (Clinical) View for NDH",
  "status": "draft",
  "description": "Flattened view of FHIR Organization resources (type='prov') for National Directory of Healthcare Providers",
  "resource": "Organization",
  "fhirVersion": ["4.0.1"],
  "select": [
    {
      "column": [
        {
          "name": "resource_uuid",
          "path": "id",
          "description": "FHIR resource ID"
        },
        {
          "name": "npi",
          "path": "identifier.where(system='http://hl7.org/fhir/sid/us-npi').value.first()",
          "description": "National Provider Identifier"
        },
        {
          "name": "active",
          "path": "active",
          "description": "Whether the organization is active"
        },
        {
          "name": "name",
          "path": "name",
          "description": "Legal business name"
        },
        {
          "name": "description",
          "path": "extension.where(url='http://hl7.org/fhir/us/ndh/StructureDefinition/base-ext-org-description').valueString.first()",
          "description": "Organization description"
        },
        {
          "name": "part_of_reference",
          "path": "partOf.reference",
          "description": "Parent organization reference (e.g., 'Organization/789')"
        },
        {
          "name": "organization_type_code",
          "path": "type[0].coding[0].code",
          "description": "Organization type code (for filtering prov)"
        }
      ]
    }
  ]
}
