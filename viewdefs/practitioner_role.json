{
  "resourceType": "ViewDefinition",
  "url": "http://example.org/fhir/ViewDefinition/practitioner_role",
  "name": "practitioner_role",
  "title": "PractitionerRole View for NDH",
  "status": "draft",
  "description": "Flattened view of FHIR PractitionerRole resources for National Directory of Healthcare Providers",
  "resource": "PractitionerRole",
  "fhirVersion": ["4.0.1"],
  "select": [
    {
      "column": [
        {
          "name": "resource_uuid",
          "path": "id",
          "description": "FHIR resource ID"
        },
        {
          "name": "active",
          "path": "active",
          "description": "Whether the role is active"
        },
        {
          "name": "practitioner_reference",
          "path": "practitioner.reference",
          "description": "Practitioner reference (e.g., 'Practitioner/123')"
        },
        {
          "name": "organization_reference",
          "path": "organization.reference",
          "description": "Organization reference (e.g., 'Organization/456')"
        },
        {
          "name": "code_system",
          "path": "code[0].coding[0].system",
          "description": "Practitioner role code system"
        },
        {
          "name": "code_code",
          "path": "code[0].coding[0].code",
          "description": "Practitioner role code"
        },
        {
          "name": "code_display",
          "path": "code[0].coding[0].display",
          "description": "Practitioner role display text"
        },
        {
          "name": "location_reference",
          "path": "location[0].reference",
          "description": "Location reference (CMS-constrained to 0..1, e.g., 'Location/789')"
        },
        {
          "name": "healthcare_service_reference",
          "path": "healthcareService[0].reference",
          "description": "HealthcareService reference (CMS-constrained to 0..1, e.g., 'HealthcareService/101')"
        },
        {
          "name": "accepting_new_patients",
          "path": "extension.where(url='http://hl7.org/fhir/us/ndh/StructureDefinition/base-ext-newpatients').valueBoolean.first()",
          "description": "Whether accepting new patients"
        },
        {
          "name": "rating",
          "path": "extension.where(url='http://hl7.org/fhir/us/ndh/StructureDefinition/base-ext-rating').valueInteger.first()",
          "description": "Rating value"
        }
      ]
    }
  ]
}
